{
  "name": "code-memory",
  "version": "0.1.0",
  "type": "module",
  "description": "AI Project Cognitive Engine — Code Memory Graph with MCP integration",
  "main": "dist/index.js",
  "bin": {
    "code-memory": "./dist/index.js"
  },
  "files": [
    "dist",
    "grammars",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run lint && npm run build && npm test",
    "audit:official": "npm audit --registry=https://registry.npmjs.org",
    "pack:check": "npm pack --dry-run",
    "test:smoke": "npm run build && node tools/pack-smoke.mjs",
    "start": "node dist/index.js",
    "benchmark:index": "node tools/benchmark-index.mjs"
  },
  "keywords": [
    "code-intelligence",
    "mcp",
    "code-graph",
    "symbol-index",
    "ai-context",
    "tree-sitter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "ignore": "^6.0.0",
    "nanoid": "^5.0.0",
    "web-tree-sitter": "^0.26.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0"
  }
}
