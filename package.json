{
  "name": "@keweixin/code-memory",
  "version": "0.3.5",
  "type": "module",
  "description": "Context Ledger and evidence-backed code graph for AI coding agents",
  "author": "keweixin",
  "main": "dist/index.js",
  "bin": {
    "code-memory": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/*.md",
    "grammars",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keweixin/code-memory.git"
  },
  "homepage": "https://github.com/keweixin/code-memory#readme",
  "bugs": {
    "url": "https://github.com/keweixin/code-memory/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node tools/vitest-compat.mjs run --testTimeout=30000",
    "test:coverage": "node tools/vitest-compat.mjs run --testTimeout=30000 --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run lint && npm run build && npm test",
    "audit:official": "node tools/npm-audit-official.mjs",
    "pack:check": "node tools/pack-check.mjs",
    "test:smoke": "npm run build && node tools/pack-smoke.mjs",
    "start": "node dist/index.js",
    "benchmark:index": "node tools/benchmark-index.mjs",
    "benchmark:context": "node tools/benchmark-context.mjs",
    "benchmark:agent": "node tools/benchmark-agent.mjs",
    "benchmark:gate": "node tools/benchmark-quality-gate.mjs",
    "bench": "vitest run tests/bench/"
  },
  "keywords": [
    "code-intelligence",
    "mcp",
    "mcp-server",
    "code-graph",
    "context-ledger",
    "symbol-index",
    "ai-context",
    "ai-agent",
    "local-first",
    "tree-sitter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "commander": "^13.0.0",
    "ignore": "^7.0.5",
    "nanoid": "^5.0.0",
    "web-tree-sitter": "^0.26.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
